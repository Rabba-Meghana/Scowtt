# ── Database ─────────────────────────────────────────────────────────────────
# Docker Compose default — change for production
DATABASE_URL="postgresql://moviememory:moviememory@localhost:5432/moviememory"

# Postgres Docker overrides (used by docker-compose.yml)
POSTGRES_USER=moviememory
POSTGRES_PASSWORD=moviememory
POSTGRES_DB=moviememory

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-secure-random-string"

# App URL — used by NextAuth for callbacks
NEXTAUTH_URL="http://localhost:3000"

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# ── App Config ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
TMDB_API_KEY="your-tmdb-api-key-here"
